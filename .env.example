# ============================================================
#  IBM Watsonx.ai Configuration  — copy to .env and fill in
# ============================================================
IBM_API_KEY=your_ibm_cloud_api_key_here
IBM_PROJECT_ID=your_watsonx_project_id_here
IBM_WATSONX_URL=https://au-syd.dai.cloud.ibm.com/

# ============================================================
#  Flask Configuration
# ============================================================
FLASK_SECRET_KEY=change_this_to_a_strong_random_secret_key
FLASK_ENV=development
FLASK_DEBUG=False

# ============================================================
#  Model Configuration
# ============================================================
GRANITE_MODEL_ID=ibm/granite-3-3-8b-instruct

# ============================================================
#  RAG Configuration
# ============================================================
EMBEDDING_MODEL=all-MiniLM-L6-v2
KNOWLEDGE_BASE_DIR=knowledge_base
VECTOR_DB_PATH=vector_db
TOP_K_RESULTS=5

# ============================================================
#  Upload Configuration
# ============================================================
MAX_CONTENT_LENGTH=10485760
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=pdf,docx,doc,txt

# ============================================================
#  Chat Configuration
# ============================================================
MAX_HISTORY_MESSAGES=6
MAX_TOKENS=1024
TEMPERATURE=0.7
